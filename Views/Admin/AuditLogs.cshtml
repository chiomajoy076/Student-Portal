@model Student_Portal.ViewModels.PagedAuditLogViewModel
@{
    ViewData["Title"] = "Audit Logs";
    Layout = "_AdminLayout";
}

<h2>Audit Logs</h2>
<p class="text-muted">
    Showing @Model.Items.Count of @Model.TotalCount activity log entries
    (page @Model.Page of @Math.Max(Model.TotalPages, 1)).
</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="email" value="@Model.EmailFilter" class="form-control"
               placeholder="Filter by email" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="AuditLogs" class="btn btn-secondary">Reset</a>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Timestamp (UTC)</th>
            <th>User</th>
            <th>Action</th>
            <th>IP Address</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model.Items)
        {
            <tr>
                <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>@(log.UserEmail ?? "(unknown)")</td>
                <td>@log.Action</td>
                <td>@(log.IPAddress ?? "-")</td>
            </tr>
        }
    </tbody>
</table>

<partial name="_Pagination" model="@(new Student_Portal.ViewModels.PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    Action = "AuditLogs",
    RouteValues = new Dictionary<string, string> { ["email"] = Model.EmailFilter ?? "" }
})" />
