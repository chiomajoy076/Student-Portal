@model Student_Portal.ViewModels.PagedResult<Student_Portal.ViewModels.StudentListViewModel>
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<h2>Student Management</h2>
<p class="text-muted">
    Showing @Model.Items.Count of @Model.TotalCount students
    (page @Model.Page of @Math.Max(Model.TotalPages, 1)).
</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control"
               placeholder="Search by name, email, matric number or department" />
    </div>
    <div class="col-md-3">
        <select name="status" class="form-control">
            <option value="" selected="@(ViewBag.Status == null ? "selected" : null)">All Statuses</option>
            <option value="active" selected="@(ViewBag.Status == "active" ? "selected" : null)">Active</option>
            <option value="inactive" selected="@(ViewBag.Status == "inactive" ? "selected" : null)">Inactive</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="Index" class="btn btn-secondary">Reset</a>
    </div>
</form>

<table class="table">
    <thead>
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Matric No.</th>
        <th>Department</th>
        <th>Phone Number</th>
        <th>Status</th>
        <th>Registration Date</th>
        <th>Form Status</th>
        <th>Actions</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var student in Model.Items)
    {
        <tr>
            <td>@student.FullName</td>
            <td>@student.Email</td>
            <td>@student.MatricNumber</td>
            <td>@student.Department</td>
            <td>@student.PhoneNumber</td>
            <td>@(student.IsActive ? "Active" : "Inactive")</td>
            <td>@student.CreatedAt.ToString("d")</td>
            <td>@(student.HasSubmittedForm ? "Submitted" : "Pending")</td>
            <td>
                <a asp-action="StudentDetails" asp-route-id="@student.Id"
                   class="btn btn-info btn-sm">Details</a>
            </td>
        </tr>
    }
    </tbody>
</table>

<partial name="_Pagination" model="@(new Student_Portal.ViewModels.PaginationViewModel
{
    Page = Model.Page,
    TotalPages = Model.TotalPages,
    Action = "Index",
    RouteValues = new Dictionary<string, string>
    {
        ["search"] = ViewBag.Search ?? "",
        ["status"] = ViewBag.Status ?? ""
    }
})" />
