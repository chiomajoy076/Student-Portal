@using Student_Portal.Models
@{
    ViewData["Title"] = "Manage Lecturer Departments";
    Layout = "_AdminLayout";
    var lecturerId = ViewBag.LecturerId as string;
    var current = ViewBag.CurrentDepartments as List<string> ?? new List<string>();
}

<h2>Manage Lecturer Departments</h2>
<p class="text-muted">Select every department this lecturer can access courses and results for.</p>

<form asp-action="ManageLecturerDepartments" method="post">
    <input type="hidden" name="id" value="@lecturerId" />

    @foreach (var dept in Departments.All)
    {
        <div class="form-check">
            <input type="checkbox" name="departments" value="@dept" class="form-check-input"
                   id="dept-@dept.Replace(" ", "")" checked="@(current.Contains(dept) ? "checked" : null)" />
            <label class="form-check-label" for="dept-@dept.Replace(" ", "")">@dept</label>
        </div>
    }

    <button type="submit" class="btn btn-primary mt-3">Save</button>
    <a asp-action="Users" class="btn btn-secondary mt-3">Cancel</a>
</form>
