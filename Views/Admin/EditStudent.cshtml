@model Student_Portal.ViewModels.EditStudentViewModel
@using Student_Portal.Models
@{
    ViewData["Title"] = "Edit Student";
    Layout = "_AdminLayout";
}

<h2>Edit Student Record</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="EditStudent" method="post" class="row g-3">
    <input type="hidden" asp-for="Id" />

    <div class="col-md-4">
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="MiddleName"></label>
        <input asp-for="MiddleName" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="LastName"></label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="col-md-4">
        <label asp-for="PhoneNumber"></label>
        <input asp-for="PhoneNumber" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Gender"></label>
        <select asp-for="Gender" class="form-control" asp-items="Html.GetEnumSelectList<Student_Portal.Models.Gender>()">
            <option value="">-- Select Gender --</option>
        </select>
    </div>

    <div class="col-md-4">
        <label asp-for="MatricNumber"></label>
        <input asp-for="MatricNumber" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Department"></label>
        <select asp-for="Department" class="form-control">
            <option value="">Select Department</option>
            @foreach (var dept in Departments.All)
            {
                <option value="@dept">@dept</option>
            }
        </select>
    </div>
    <div class="col-md-4">
        <label asp-for="Level"></label>
        <select asp-for="Level" class="form-control">
            <option value="">Select Level</option>
            <option value="100">100 Level</option>
            <option value="200">200 Level</option>
            <option value="300">300 Level</option>
            <option value="400">400 Level</option>
        </select>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary mt-2">Save Changes</button>
        <a asp-action="StudentDetails" asp-route-id="@Model.Id" class="btn btn-secondary mt-2">Cancel</a>
    </div>
</form>
