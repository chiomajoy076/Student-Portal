@model Student_Portal.ViewModels.ResultCheckViewModel
@using Student_Portal.ViewModels
@{
    ViewData["Title"] = "Check Result";
    var periods = ViewBag.Periods as List<AcademicPeriod> ?? new List<AcademicPeriod>();
}

<div class="form-page-wrapper d-print-none">
    <div class="card form-card">
        <div class="card-body">
            <h2>Check Result</h2>
            <form method="get" class="row g-3">
                <div class="col-md-6 form-group">
                    <label>Session / Semester</label>
                    <select name="session_semester" class="form-control" onchange="
                        var parts = this.value.split('|');
                        window.location.href = '@Url.Action("CheckResult")?session=' + encodeURIComponent(parts[0]) + '&semester=' + parts[1];
                    ">
                        <option value="">-- Select Session / Semester --</option>
                        @foreach (var period in periods)
                        {
                            var selected = Model != null && Model.Session == period.Session && Model.Semester == period.Semester;
                            <option value="@period.Session|@((int)period.Semester)" selected="@(selected ? "selected" : null)">
                                @period.Label
                            </option>
                        }
                    </select>
                </div>
            </form>

            @if (Model == null)
            {
                <div class="alert alert-info mt-3 mb-0">
                    Select a session and semester above to view your result.
                </div>
            }
        </div>
    </div>
</div>

@if (Model != null)
{
    <div id="printable" class="form-page-wrapper mt-3">
    <div class="card form-card">
    <div class="card-body">
        <div class="text-center mb-4">
            <h3>AE-FUNAI Result Slip</h3>
            <p>@Model.Session - @Model.Semester Semester</p>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <strong>Name:</strong> @Model.FullName
            </div>
            <div class="col-md-6">
                <strong>Matric Number:</strong> @Model.MatricNumber
            </div>
            <div class="col-md-6">
                <strong>Department:</strong> @Model.Department
            </div>
            <div class="col-md-6">
                <strong>Level:</strong> @Model.Level
            </div>
        </div>

        <div class="table-responsive">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Course Code</th>
                    <th>Course Title</th>
                    <th>Credit Unit</th>
                    <th>Score</th>
                    <th>Grade</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model.Courses)
                {
                    <tr>
                        <td>@course.CourseCode</td>
                        <td>@course.CourseTitle</td>
                        <td>@course.CreditUnit</td>
                        <td>@course.Score</td>
                        <td>@course.Grade</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        <div class="row mt-3">
            <div class="col-md-3">
                <strong>GPA:</strong> @Model.GPA.ToString("0.00")
            </div>
            <div class="col-md-3">
                <strong>CGPA:</strong> @Model.CGPA.ToString("0.00")
            </div>
        </div>
    </div>
    </div>
    </div>

    <div class="form-page-wrapper d-print-none mt-3">
        <button onclick="window.print()" class="btn btn-primary">Print Result</button>
    </div>
}

<style>
    @@media print {
        .navbar, footer, .d-print-none {
            display: none !important;
        }
    }
</style>
