@model Student_Portal.ViewModels.ForgotPasswordViewModel
@{
    var context = ViewBag.Context as string ?? "student";
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-icon">&#128273;</div>
        <h2>Forgot Password</h2>
        <p class="auth-subtitle">Enter your email address to reset your password.</p>
        <form asp-action="@(context == "admin" ? "AdminForgotPassword" : "ForgotPassword")" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Continue</button>
            <div class="auth-footer">
                @if (context == "admin")
                {
                    <a asp-action="AdminLogin">Back to Admin Login</a>
                }
                else
                {
                    <a asp-action="StudentLogin">Back to Student Login</a>
                }
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
