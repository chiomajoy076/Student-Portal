@model Student_Portal.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Student Login";
    Layout = "_Layout";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-icon">&#127891;</div>
        <h2>@ViewData["Title"]</h2>
        <p class="auth-subtitle">Sign in to manage your registration and results</p>
        <form asp-action="StudentLogin" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>
            <button type="submit" class="btn btn-primary">Student Log in</button>
            <div class="auth-footer">
                <a asp-action="ForgotPassword">Forgot password?</a>
            </div>
            <div class="auth-footer">
                <a asp-action="StudentRegister">Register as new student</a>
            </div>
        </form>
    </div>
</div>
