@{
    ViewData["Title"] = "Password Reset Complete";
    Layout = "_Layout";
    var context = ViewBag.Context as string ?? "student";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-icon">&#9989;</div>
        <h2>Password Reset</h2>
        <p class="auth-subtitle">Your password has been updated. You can now log in with your new password.</p>
        <div class="d-flex justify-content-center">
            @if (context == "admin")
            {
                <a asp-action="AdminLogin" class="btn btn-outline-primary w-auto">Admin Login</a>
            }
            else
            {
                <a asp-action="StudentLogin" class="btn btn-outline-primary w-auto">Student Login</a>
            }
        </div>
    </div>
</div>
